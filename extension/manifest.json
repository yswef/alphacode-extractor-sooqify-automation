{
  "manifest_version": 3,
  "name": "AlphaCode Product Extractor",
  "version": "4.3.0",
  "description": "AlphaCode batch product queue with bilingual AI copy, six-image Sooqify uploads, official-site research, notifications, and sequential low-resource submission.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "*://*.szwego.com/*",
    "http://127.0.0.1:5000/*",
    "https://admin.sooqifyonline.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.szwego.com/*"
      ],
      "js": [
        "page_bridge.js"
      ],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.szwego.com/*"
      ],
      "js": [
        "config.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://admin.sooqifyonline.com/admin/item/*"
      ],
      "js": [
        "config.js",
        "admin_autofill.js"
      ],
      "css": [
        "admin_autofill.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
